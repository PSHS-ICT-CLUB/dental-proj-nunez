{
	"name": "dental-proj",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:all": "concurrently \"bun run bot\" \"vite dev\"",
		"build": "vite build",
		"preview": "concurrently \"bun run bot\" \"vite preview\"",
		"preview:solo": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"db:push": "drizzle-kit push",
		"db:migrate": "drizzle-kit migrate",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"bot": "bun run src/bot.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/vite": "^4.0.0",
		"@types/node": "^22",
		"concurrently": "^9.2.1",
		"drizzle-kit": "^0.30.2",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.0.0",
		"vite": "^6.2.6"
	},
	"dependencies": {
		"@auth/core": "^0.34.3",
		"@auth/sveltekit": "^1.11.1",
		"@supabase/supabase-js": "^2.98.0",
		"chart.js": "^4.4.9",
		"date-fns": "^4.1.0",
		"discord.js": "^14.14.1",
		"drizzle-orm": "^0.40.0",
		"postgres": "^3.4.5"
	}
}
